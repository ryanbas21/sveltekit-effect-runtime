{
  "name": "sveltekit-effect-runtime",
  "version": "1.3.0",
  "description": "Runtime helpers for using Effect in SvelteKit server APIs",
  "keywords": [
    "effect",
    "effect-ts",
    "runtime",
    "svelte",
    "sveltekit"
  ],
  "homepage": "https://github.com/RATIU5/sveltekit-effect-runtime",
  "bugs": {
    "url": "https://github.com/RATIU5/sveltekit-effect-runtime/issues"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "RATIU5",
      "url": "https://github.com/RATIU5"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RATIU5/sveltekit-effect-runtime"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint:check": "oxlint src",
    "lint": "oxlint --fix src",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "test": "vitest run",
    "prepack": "bun run build",
    "prepublishOnly": "bun typecheck && bun lint:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@changesets/config": "^3.1.3",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.50.2",
    "effect": "^4.0.0-beta.76",
    "typescript": "^5.9.3"
  }
}
